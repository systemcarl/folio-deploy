source "$(dirname "${BASH_SOURCE[0]}")/utils/deployment"

deploy() {
    local loc=false
    local approve=false
    parse_environment_args "$@"
    if [[ $? -ne 0 ]]; then return 1; fi
    loc=$(parse_local_arg "$@")
    if [[ $? -ne 0 ]]; then return 1; fi
    approve=$(parse_approve_arg "$@")
    if [[ $? -ne 0 ]]; then return 1; fi

    if [[ "$loc" = false ]]; then
        echo "Initializing Terraform..."
        terraform init
        if [[ $? -ne 0 ]]; then
            echo "Failed to initialize Terraform."
            return 1
        fi
        echo "Deploying to production environment..."
        terraform plan -out=tfplan \
            -var "namespace=$FOLIO_GH_NAMESPACE" \
            -var "domain=$FOLIO_APP_DOMAIN" \
            -var "dns_zone=$FOLIO_CF_DNS_ZONE" \
            -var "ssh_port=$FOLIO_SSH_PORT" \
            -var "ssh_public_key_file=$FOLIO_PUBLIC_KEY_FILE" \
            -var "cf_token=$FOLIO_CF_TOKEN" \
            -var "do_token=$FOLIO_DO_TOKEN "
        if [[ $? -ne 0 ]]; then
            echo "Failed to create Terraform plan."
            return 1
        fi
        if [[ "$approve" != true ]]; then
            echo "Deploy $ENVIRONMENT configuration to $FOLIO_APP_DOMAIN? (y/n)"
            read -r response
            if [[ ! "$response" =~ ^[Yy]$ ]]; then
                echo "Deployment aborted."
                return 0
            fi
        fi
        terraform apply tfplan
        if [[ $? -ne 0 ]]; then
            echo "Failed to apply Terraform plan."
            return 1
        fi
        echo "Deployment of $ENVIRONMENT completed successfully."
        return 0
    fi

    if docker image inspect "$FOLIO_GH_PACKAGE:latest" > /dev/null 2>&1; then
        docker run -d \
            --name folio \
            -p 3000:3000 \
            "$FOLIO_GH_PACKAGE:latest"
    else
        echo "Docker image '$FOLIO_GH_PACKAGE:latest' not found locally."
        echo "Pulling the latest image from GitHub Container Registry..."
        if [[ -z "$FOLIO_GH_NAMESPACE" ]]; then
            echo "Error: GitHub namespace is required to retrieve image."
            usage
            return 1
        fi
        docker pull "ghcr.io/$FOLIO_GH_NAMESPACE/$FOLIO_GH_PACKAGE:latest"
        if [[ $? -ne 0 ]]; then
            echo "Failed to pull Docker image from GitHub Container Registry."
            echo "Build the image locally with 'containerize' script."
            return 1
        fi
        docker run -d \
            --name folio \
            -p 3000:3000 \
            "ghcr.io/$FOLIO_GH_NAMESPACE/$FOLIO_GH_PACKAGE:latest"
    fi
    if [[ $? -ne 0 ]]; then
        echo "Failed to start the application."
        return 1
    fi
    echo "Application is running on http://localhost:3000"
}
